{
  "name": "orderdrop-backend",
  "version": "1.0.0",
  "description": "Backend API for the OrderDrop local delivery platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.6.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^7.0.11",
    "socket.io": "^4.8.3",
    "stripe": "^14.8.0"
  },
  "optionalDependencies": {
    "sharp": "^0.32.6"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "nodemon": "^3.0.2"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "node": true,
      "es2021": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "no-console": [
        "off"
      ],
      "semi": [
        "error",
        "always"
      ]
    }
  },
  "keywords": [
    "grocery",
    "delivery",
    "api",
    "mysql",
    "express"
  ],
  "author": "OrderDrop Team",
  "license": "MIT"
}
