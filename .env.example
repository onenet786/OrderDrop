# Example environment variables for OrderDrop
# Copy this file to .env and replace placeholder values with real credentials.

# Server
PORT=3002
NODE_ENV=development
PUBLIC_BASE_URL=https://orderdrop.flaura.pk

# JWT
JWT_SECRET=your_secret_key_here_change_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE_DAYS=30

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=orderdrop

# Upload Configuration
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880

# Email Configuration
EMAIL_USER=support@orderdrop.flaura.pk
EMAIL_PASS=your_app_password_here
SUPPORT_EMAIL=support@orderdrop.flaura.pk
APP_NAME=OrderDrop
APP_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.onenetsol.servenow
APP_ANDROID_PACKAGE=com.onenetsol.servenow

# CORS Configuration (for production)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://orderdrop.flaura.pk,http://localhost:3002,http://localhost:3001

# Restore safety
# Set to true only when you intend to run a DB restore from the admin UI
ENABLE_RESTORE=false
RESTORE_PASSPHRASE=change_this_to_a_strong_passphrase

# Rate Limiting (optional - defaults in server.js)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# Logging Configuration (optional)
# MORGAN_FORMAT=dev
# LOG_LEVEL=debug

# Stripe Configuration (optional - for payment processing)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal Configuration (optional - for payment processing)
# PAYPAL_CLIENT_ID=...
# PAYPAL_SECRET=...

# Firebase Admin (required for mobile push notifications)
# Option 1: full JSON in one line (escape newlines/quotes as needed)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option 2: absolute path to service account JSON file on server
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/firebase-service-account.json
