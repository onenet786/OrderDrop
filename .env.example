# Example environment variables for ServeNow
# Copy this file to .env and replace placeholder values with real credentials.

# Server
PORT=3002
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=servenow

# Optional: restrict allowed origins (comma separated)
# ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3000

# Restore safety
# Set to true only when you intend to run a DB restore from the admin UI
ENABLE_RESTORE=false
RESTORE_PASSPHRASE=change_this_to_a_strong_passphrase
# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=servenow
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Server Configuration
PORT=3002
NODE_ENV=development

# Upload Configuration
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# CORS Configuration (for production)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3001

# Rate Limiting (optional - defaults in server.js)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# Logging Configuration (optional)
# MORGAN_FORMAT=dev (dev|combined|short|tiny)
# LOG_LEVEL=debug (debug|info|warn|error)

# Stripe Configuration (optional - for payment processing)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal Configuration (optional - for payment processing)
# PAYPAL_CLIENT_ID=...
# PAYPAL_SECRET=...
